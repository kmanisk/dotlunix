# [1] ENVIRONMENT VARIABLES & PATH
# -----------------------------------------------------------------------------

export TERMINAL='kitty'
export EDITOR='nvim'
export VISUAL='nvim'
export BROWSER=firefox

# Parallelism: Use ALL available processing units.
export MAKEFLAGS="-j$(nproc)"

# Pyenv (commented out but preserved)
