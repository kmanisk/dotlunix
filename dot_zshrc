# Create directory and cd into it
mkcd() {
  mkdir -p "$1" && cd "$1"
}

# Weather via wttr.in
# Usage: wthr [location] | wthr -s [location]
wthr() {
    if [[ "$1" == "-s" ]]; then
        shift
        local location="${(j:+:)@}"
        curl "wttr.in/${location}?format=%c+%t"
    else
        local location="${(j:+:)@}"
        curl "wttr.in/${location}"
    fi
}

# Bind Waydroid pictures to ZRAM
waydroid_bind() {
    local target="$HOME/.local/share/waydroid/data/media/0/Pictures"
    local source="/mnt/zram1"
    sudo umount -R "$target" 2>/dev/null || true
    if [[ -d "$source" ]]; then
        sudo mount --bind "$source" "$target"
        echo "Successfully bound $source to Waydroid Pictures."
    else
        echo "Error: Source $source does not exist."
        return 1
    fi
}

# Intercept 'sudo nvim' → sudoedit  (use 'command sudo nvim' to bypass)
sudo() {
    if [[ "$1" == "nvim" ]]; then
        shift
        if [[ $# -eq 0 ]]; then
            echo "Error: sudoedit requires a filename."
            return 1
        fi
        command sudoedit "$@"
    else
        command sudo "$@"
    fi
}

# Yazi — cd on exit
y() {
    local tmp cwd
    tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(cat -- "$tmp")" && [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

# Make script executable and run it
unalias chx 2>/dev/null
chx() {
    chmod +x "$1" && ./"$1"
}

# Open file manager (default: thunar)
e() {
    local filemanager="thunar"
    local target="${1:-.}"
    "$filemanager" "$target"
}

# LM Studio (latest appimage)
llm() {
    /mnt/media/Documents/do_not_delete_linux/appimages/LM-Studio*(Om[1]) "$@"
}

# System fuzzy search + smart cd
fs() {
    local target
    target=$(fd --hidden --follow --exclude .git 2>/dev/null \
        | fzf --height=40% --layout=reverse --border --prompt="search> ")
    [[ -z "$target" ]] && return 0
    if [[ -d "$target" ]]; then
        cd "$target" || return 1
    elif [[ -f "$target" ]]; then
        cd "$(dirname "$target")" || return 1
    fi
}

# ---------------------------------------------------------------------------
# ff — FZF file/folder finder with clipboard support
#
# Usage:
#   ff           → interactive fzf menu; selected path is printed AND copied
#                  to clipboard (wl-copy)
#   ff <query>   → pre-filter fzf with query; same behaviour on selection
#
# The selected path is always printed to stdout so you can also use it as:
#   cd "$(ff)"   or   nvim "$(ff)"
# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------
# ff — FZF file/folder finder
#
# Usage:
#   ff           → interactive fzf menu
#   ff <query>   → pre-filter fzf with query
#
# Behaviour on selection:
#   directory → cd into it (via zoxide-aware cd)
#   file      → open in nvim
#   always    → path copied to clipboard
# ---------------------------------------------------------------------------
ff() {
    if ! command -v fzf >/dev/null; then
        echo "ff: fzf is not installed" >&2
        return 1
    fi

    local query="${*}"
    local selected

    selected=$(
        fd --hidden --follow --exclude .git 2>/dev/null \
        | fzf \
            --height=50% \
            --layout=reverse \
            --border \
            --prompt="  find> " \
            --preview='
                if [ -d {} ]; then
                    eza --icons --color=always --group-directories-first {} 2>/dev/null \
                        || ls --color=always {}
                else
                    bat --style=numbers --color=always {} 2>/dev/null \
                        || cat {}
                fi
            ' \
            --preview-window='right:50%:wrap' \
            --query="$query"
    )

    [[ -z "$selected" ]] && return 0

    local abs_path
    abs_path="$(realpath -- "$selected")"

    # Copy to clipboard
    if command -v wl-copy >/dev/null; then
        printf '%s' "$abs_path" | wl-copy
        echo "  Copied to clipboard: $abs_path" >&2
    elif command -v xclip >/dev/null; then
        printf '%s' "$abs_path" | xclip -selection clipboard
        echo "  Copied to clipboard: $abs_path" >&2
    elif command -v xsel >/dev/null; then
        printf '%s' "$abs_path" | xsel --clipboard --input
        echo "  Copied to clipboard: $abs_path" >&2
    fi

    # Smart open
    if [[ -d "$abs_path" ]]; then
        echo "  → cd $abs_path" >&2
        cd "$abs_path"
    elif [[ -f "$abs_path" ]]; then
        echo "  → nvim $abs_path" >&2
        nvim "$abs_path"
    fi
}

# ---------------------------------------------------------------------------
# Package management helpers
# ---------------------------------------------------------------------------

# Search packages
s() { paru -Ss "$@" }

# Install packages
i() { paru -S --noconfirm --needed "$@" }

# Remove packages (with protection list)
d() {
    local -a protected=(
        linux linux-lts linux-zen
        systemd systemd-libs
        glibc gcc
        bash zsh
        pacman paru
        sudo
        dbus
        util-linux
        base base-devel
    )

    [[ $# -eq 0 ]] && { echo "d: no package specified"; return 1 }

    for pkg in "$@"; do
        for p in "${protected[@]}"; do
            [[ "$pkg" == "$p" ]] && {
                echo "d: refusing to remove protected package: $pkg"
                return 1
            }
        done
    done

    if paru -Qi "$@" >/dev/null 2>&1; then
        paru -Rns --noconfirm "$@"
    else
        echo "d: package not installed"
        return 1
    fi
}

# Update everything
updateall() {
    echo "==> Updating official packages (pacman)..."
    sudo pacman -Syu --noconfirm
    if command -v paru >/dev/null 2>&1; then
        echo "==> Updating AUR packages (paru)..."
        paru -Syu --noconfirm
    fi
    echo "==> Done!"
}

# ---------------------------------------------------------------------------
# Pacman / Expac Metrics
# ---------------------------------------------------------------------------

# Largest packages (all, including deps)
pkg_hogs_all() { expac '%m\t%n' | sort -rn | head -n "${1:-20}" | numfmt --to=iec-i --suffix=B --field=1 }

# Largest packages (explicitly installed only)
pkg_hogs() { pacman -Qeq | expac '%m\t%n' - | sort -rn | head -n "${1:-20}" | numfmt --to=iec-i --suffix=B --field=1 }

# Recently installed
pkg_new() { expac --timefmt='%Y-%m-%d %T' '%l\t%n' | sort -r | head -n "${1:-20}" }

# Oldest packages
pkg_old() { expac --timefmt='%Y-%m-%d %T' '%l\t%n' | sort | head -n "${1:-20}" }

# ---------------------------------------------------------------------------
# Windows 10 KVM Manager
#
# win start    — start VM
# win view     — open Looking Glass
# win launch   — start + wait + open Looking Glass
# win shutdown — ACPI shutdown
# win kill     — force destroy
# win reboot   — reboot VM
# win status   — show VM state
# win edit     — edit VM XML
# ---------------------------------------------------------------------------
win() {
    local vm="win10"
    local shm_file="/dev/shm/looking-glass"
    local lg_cmd="looking-glass-client -f ${shm_file} -m KEY_F6"

    # FIX: local functions are not valid zsh — use local variables with print
    local _info="echo -e \"\e[34m[WIN10]\e[0m\""
    local _err="echo -e \"\e[31m[ERROR]\e[0m\""

    case "$1" in
        start)
            echo -e "\e[34m[WIN10]\e[0m Starting VM..."
            sudo virsh start "$vm"
            ;;
        stop|shutdown)
            echo -e "\e[34m[WIN10]\e[0m Sending shutdown signal..."
            sudo virsh shutdown "$vm"
            ;;
        kill|destroy)
            echo -e "\e[34m[WIN10]\e[0m Forcefully destroying VM..."
            sudo virsh destroy "$vm"
            ;;
        reboot)
            echo -e "\e[34m[WIN10]\e[0m Rebooting VM..."
            sudo virsh reboot "$vm"
            ;;
        view|lg|show)
            if [[ -f "$shm_file" ]]; then
                echo -e "\e[34m[WIN10]\e[0m Launching Looking Glass..."
                eval "$lg_cmd"
            else
                echo -e "\e[31m[ERROR]\e[0m Looking Glass SHM file not found. Is the VM running?"
            fi
            ;;
        launch|play)
            echo -e "\e[34m[WIN10]\e[0m Two birds one stone: Starting VM and waiting for Looking Glass..."
            sudo virsh start "$vm" 2>/dev/null
            echo -e "\e[34m[WIN10]\e[0m Waiting for Shared Memory..."
            local timeout=30
            while [[ ! -f "$shm_file" && $timeout -gt 0 ]]; do
                sleep 1
                (( timeout-- ))
            done
            if [[ -f "$shm_file" ]]; then
                echo -e "\e[34m[WIN10]\e[0m Ready! Launching Client..."
                eval "$lg_cmd"
            else
                echo -e "\e[31m[ERROR]\e[0m Timed out waiting for VM graphics."
            fi
            ;;
        status)
            sudo virsh domstate "$vm"
            ;;
        edit)
            sudo virsh edit "$vm"
            ;;
        *)
            echo "Usage: win {start|shutdown|destroy|reboot|view|launch|status|edit}"
            ;;
    esac
}

